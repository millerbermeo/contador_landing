---
const servicios = [
  "Asesoría Tributaria",
  "Contabilidad General",
  "Revisoría Fiscal y Auditoría",
  "Gestión Laboral",
  "Planeación Financiera",
  "Constitución Empresarial",
];

const enlaces = [
  { label: "Inicio", href: "#contador" },
  { label: "Servicios", href: "#servicios" },
  { label: "Nosotros", href: "#nosotros" },
  { label: "Planes", href: "#precios" },
  { label: "Preguntas Frecuentes", href: "#faq" },
];
---

<footer class="bg-[#0f2d1f] text-white" aria-labelledby="footer-heading">
  <h2 id="footer-heading" class="sr-only">Pie de página</h2>

  <!-- Banda superior CTA -->
  <div class="bg-gradient-to-r from-[#2d6a4f] to-[#1b4332] py-12">
    <div class="container mx-auto px-4 lg:px-8 flex flex-col lg:flex-row items-center justify-between gap-6">
      <div>
        <h3 class="text-2xl lg:text-3xl font-extrabold text-white leading-tight">
          ¿Listo para optimizar sus finanzas?
        </h3>
        <p class="text-[#b7e4c7] mt-1 text-base">
          Contáctenos hoy y reciba una asesoría personalizada sin compromiso.
        </p>
      </div>
      <a
        href="https://wa.me/573054188289"
        target="_blank"
        rel="noopener noreferrer"
        class="shrink-0 inline-flex items-center gap-2 bg-[#52b788] text-white font-bold py-3.5 px-8 rounded-full hover:bg-white hover:text-[#2d6a4f] transition-all duration-300 shadow-lg hover:shadow-xl hover:-translate-y-0.5 text-base"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Contactar por WhatsApp
      </a>
    </div>
  </div>

  <!-- Cuerpo del footer -->
  <div class="container mx-auto px-4 lg:px-8 py-16">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-8">

      <!-- Columna 1: Marca -->
      <div class="sm:col-span-2 lg:col-span-1">
        <div class="flex items-center gap-3 mb-5">
          <img src="/logotipo.jpeg" alt="BP Asesorías Contables" class="w-12 h-12 rounded-full object-cover border-2 border-[#52b788]/40" />
          <div>
            <span class="block font-bold text-white text-base">BP Asesorías</span>
            <span class="block text-[#52b788] text-xs font-semibold tracking-widest uppercase">Contables</span>
          </div>
        </div>
        <p class="text-white/60 text-sm leading-relaxed mb-6">
          Brian Pedraza Osorio, Contador Público certificado con experiencia en asesoría contable y financiera en Colombia. Comprometido con la transparencia y el crecimiento empresarial.
        </p>
        <!-- Redes sociales -->
        <div class="flex items-center gap-3">
          <a href="https://facebook.com" target="_blank" rel="noopener noreferrer" aria-label="Facebook"
             class="w-9 h-9 rounded-full bg-white/10 hover:bg-[#52b788] flex items-center justify-center transition-colors duration-200">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a href="https://tiktok.com/@bp.asesorias.contables" target="_blank" rel="noopener noreferrer" aria-label="TikTok"
             class="w-9 h-9 rounded-full bg-white/10 hover:bg-[#52b788] flex items-center justify-center transition-colors duration-200">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.18 8.18 0 004.78 1.52V6.74a4.84 4.84 0 01-1.01-.05z"/></svg>
          </a>
          <a href="https://instagram.com" target="_blank" rel="noopener noreferrer" aria-label="Instagram"
             class="w-9 h-9 rounded-full bg-white/10 hover:bg-[#52b788] flex items-center justify-center transition-colors duration-200">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
        </div>
      </div>

      <!-- Columna 2: Servicios -->
      <div>
        <h3 class="text-sm font-bold uppercase tracking-widest text-[#52b788] mb-5">Servicios</h3>
        <ul class="space-y-2.5" role="list">
          {servicios.map((s) => (
            <li class="flex items-center gap-2 text-white/60 text-sm hover:text-white transition-colors duration-200 cursor-default">
              <span class="w-1 h-1 rounded-full bg-[#52b788] shrink-0" aria-hidden="true"></span>
              {s}
            </li>
          ))}
        </ul>
      </div>

      <!-- Columna 3: Navegación -->
      <div>
        <h3 class="text-sm font-bold uppercase tracking-widest text-[#52b788] mb-5">Navegación</h3>
        <ul class="space-y-2.5" role="list">
          {enlaces.map((e) => (
            <li>
              <a href={e.href}
                 class="flex items-center gap-2 text-white/60 text-sm hover:text-white transition-colors duration-200 group">
                <svg class="w-3 h-3 text-[#52b788] group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/>
                </svg>
                {e.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Columna 4: Contacto -->
      <div>
        <h3 class="text-sm font-bold uppercase tracking-widest text-[#52b788] mb-5">Contacto</h3>
        <ul class="space-y-4" role="list">
          <li>
            <a href="mailto:b.pedraza247@gmail.com"
               class="flex items-start gap-3 text-white/60 hover:text-white transition-colors duration-200 group">
              <svg class="w-4 h-4 text-[#52b788] mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
              <span class="text-sm">b.pedraza247@gmail.com</span>
            </a>
          </li>
          <li>
            <a href="https://wa.me/573054188289"
               class="flex items-start gap-3 text-white/60 hover:text-white transition-colors duration-200">
              <svg class="w-4 h-4 text-[#52b788] mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              <span class="text-sm">305 418 8289 (WhatsApp)</span>
            </a>
          </li>
          <li>
            <a href="tel:+573134299697"
               class="flex items-start gap-3 text-white/60 hover:text-white transition-colors duration-200">
              <svg class="w-4 h-4 text-[#52b788] mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
              <span class="text-sm">313 429 9697</span>
            </a>
          </li>
          <li class="flex items-start gap-3 text-white/60">
            <svg class="w-4 h-4 text-[#52b788] mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            <span class="text-sm">Florencia, Caquetá, Colombia</span>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Barra de copyright -->
  <div class="border-t border-white/10 py-6">
    <div class="container mx-auto px-4 lg:px-8 flex flex-col sm:flex-row justify-between items-center gap-3">
      <p class="text-white/40 text-xs text-center sm:text-left">
        &copy; 2025 Brian Pedraza Osorio — Todos los derechos reservados.
      </p>
      <p class="text-white/30 text-xs text-center">
        Imágenes: <a href="https://www.freepik.es" target="_blank" rel="noopener noreferrer" class="hover:text-white/50 transition-colors">Freepik</a>
      </p>
    </div>
  </div>
</footer>
