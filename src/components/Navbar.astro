<!-- Barra de contacto superior (solo escritorio) -->
<div id="topbar" class="bg-[#1b4332] text-white text-xs lg:text-sm py-2 lg:block hidden transition-all duration-300">
  <div class="container mx-auto px-4 lg:px-8 flex justify-between items-center">
    <div class="flex items-center gap-6">
      <a href="mailto:b.pedraza247@gmail.com" aria-label="Correo electrónico"
         class="flex items-center gap-1.5 hover:text-[#b7e4c7] transition-colors duration-200">
        <ion-icon name="mail-outline"></ion-icon>
        b.pedraza247@gmail.com
      </a>
      <a href="https://wa.me/573054188289" aria-label="WhatsApp"
         class="flex items-center gap-1.5 hover:text-[#b7e4c7] transition-colors duration-200">
        <ion-icon name="logo-whatsapp"></ion-icon>
        305 418 8289
      </a>
      <a href="tel:+573134299697" aria-label="Teléfono"
         class="flex items-center gap-1.5 hover:text-[#b7e4c7] transition-colors duration-200">
        <ion-icon name="call-outline"></ion-icon>
        313 429 9697
      </a>
      <span class="flex items-center gap-1.5 text-[#b7e4c7]/80">
        <ion-icon name="location-outline"></ion-icon>
        Florencia, Caquetá
      </span>
    </div>
    <div class="flex items-center gap-5 text-base">
      <a href="https://facebook.com" target="_blank" rel="noopener noreferrer" aria-label="Facebook"
         class="hover:text-[#b7e4c7] transition-colors duration-200">
        <ion-icon name="logo-facebook"></ion-icon>
      </a>
      <a href="https://tiktok.com/@bp.asesorias.contables" target="_blank" rel="noopener noreferrer" aria-label="TikTok"
         class="hover:text-[#b7e4c7] transition-colors duration-200">
        <ion-icon name="logo-tiktok"></ion-icon>
      </a>
      <a href="https://instagram.com" target="_blank" rel="noopener noreferrer" aria-label="Instagram"
         class="hover:text-[#b7e4c7] transition-colors duration-200">
        <ion-icon name="logo-instagram"></ion-icon>
      </a>
    </div>
  </div>
</div>

<!-- Navbar principal (sticky) -->
<nav
  id="main-nav"
  class="sticky top-0 z-50 bg-white/95 backdrop-blur-md border-b border-gray-100 transition-all duration-300"
  aria-label="Navegación principal"
>
  <div class="container mx-auto px-4 lg:px-8 flex justify-between items-center py-3 lg:py-4">

    <!-- Logo -->
    <a href="#contador" class="flex items-center gap-3 group" aria-label="Ir al inicio">
      <img
        src="/logotipo.jpeg"
        alt="BP Asesorías Contables"
        class="h-10 w-10 rounded-full object-cover shadow-sm group-hover:shadow-md transition-shadow duration-300"
      />
      <div class="leading-tight">
        <span class="block text-[#1b4332] font-bold text-sm lg:text-base tracking-tight">BP Asesorías</span>
        <span class="block text-[#52b788] text-xs font-semibold tracking-widest uppercase">Contables</span>
      </div>
    </a>

    <!-- Links escritorio -->
    <div class="hidden md:flex items-center gap-8" role="navigation">
      <a href="#contador" class="nav-link text-gray-600 font-medium text-sm lg:text-base hover:text-[#2d6a4f] transition-colors relative group pb-0.5">
        Inicio
        <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-[#52b788] group-hover:w-full transition-all duration-300 rounded-full"></span>
      </a>
      <a href="#servicios" class="nav-link text-gray-600 font-medium text-sm lg:text-base hover:text-[#2d6a4f] transition-colors relative group pb-0.5">
        Servicios
        <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-[#52b788] group-hover:w-full transition-all duration-300 rounded-full"></span>
      </a>
      <a href="#nosotros" class="nav-link text-gray-600 font-medium text-sm lg:text-base hover:text-[#2d6a4f] transition-colors relative group pb-0.5">
        Nosotros
        <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-[#52b788] group-hover:w-full transition-all duration-300 rounded-full"></span>
      </a>
      <a href="#precios" class="nav-link text-gray-600 font-medium text-sm lg:text-base hover:text-[#2d6a4f] transition-colors relative group pb-0.5">
        Planes
        <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-[#52b788] group-hover:w-full transition-all duration-300 rounded-full"></span>
      </a>
      <a
        href="https://wa.me/573054188289"
        target="_blank"
        rel="noopener noreferrer"
        class="bg-[#2d6a4f] text-white px-5 py-2.5 rounded-full text-sm font-semibold hover:bg-[#1b4332] transition-all duration-300 shadow-md hover:shadow-lg hover:-translate-y-0.5 flex items-center gap-2"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Contactar ahora
      </a>
    </div>

    <!-- Botón hamburguesa (móvil) -->
    <button
      type="button"
      id="menu-toggle"
      aria-label="Abrir menú de navegación"
      aria-expanded="false"
      aria-controls="mobile-menu"
      class="md:hidden p-2 rounded-lg hover:bg-gray-100 transition-colors duration-200 focus:outline-none focus:ring-2 focus:ring-[#52b788]"
    >
      <svg id="hamburger-icon" class="w-6 h-6 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
      <svg id="close-icon" class="w-6 h-6 text-gray-700 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
  </div>
</nav>

<!-- Overlay fondo oscuro (móvil) -->
<div
  id="mobile-overlay"
  class="fixed inset-0 bg-black/50 z-40 opacity-0 invisible transition-all duration-300 md:hidden"
  aria-hidden="true"
></div>

<!-- Drawer de navegación (móvil) -->
<aside
  id="mobile-menu"
  class="fixed top-0 right-0 h-full w-72 bg-white z-50 transform translate-x-full transition-transform duration-300 ease-in-out md:hidden shadow-2xl flex flex-col"
  aria-hidden="true"
  aria-label="Menú de navegación móvil"
>
  <!-- Cabecera del drawer -->
  <div class="flex items-center justify-between p-5 border-b border-gray-100">
    <div class="flex items-center gap-3">
      <img src="/logotipo.jpeg" alt="Logo BP Asesorías" class="h-9 w-9 rounded-full object-cover" />
      <div>
        <span class="block text-[#1b4332] font-bold text-sm">BP Asesorías</span>
        <span class="block text-[#52b788] text-xs font-semibold tracking-widest uppercase">Contables</span>
      </div>
    </div>
    <button
      id="close-menu"
      class="p-2 rounded-lg hover:bg-gray-100 transition-colors duration-200 focus:outline-none focus:ring-2 focus:ring-[#52b788]"
      aria-label="Cerrar menú"
    >
      <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
  </div>

  <!-- Links del drawer -->
  <nav class="flex flex-col p-4 gap-1 flex-1" aria-label="Menú móvil">
    <a href="#contador" class="mobile-link flex items-center gap-3 py-3 px-4 rounded-xl text-gray-700 font-medium hover:bg-[#f0fdf4] hover:text-[#2d6a4f] transition-colors duration-200">
      <svg class="w-5 h-5 text-[#52b788] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
      </svg>
      Inicio
    </a>
    <a href="#servicios" class="mobile-link flex items-center gap-3 py-3 px-4 rounded-xl text-gray-700 font-medium hover:bg-[#f0fdf4] hover:text-[#2d6a4f] transition-colors duration-200">
      <svg class="w-5 h-5 text-[#52b788] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
      </svg>
      Servicios
    </a>
    <a href="#nosotros" class="mobile-link flex items-center gap-3 py-3 px-4 rounded-xl text-gray-700 font-medium hover:bg-[#f0fdf4] hover:text-[#2d6a4f] transition-colors duration-200">
      <svg class="w-5 h-5 text-[#52b788] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
      </svg>
      Nosotros
    </a>
    <a href="#precios" class="mobile-link flex items-center gap-3 py-3 px-4 rounded-xl text-gray-700 font-medium hover:bg-[#f0fdf4] hover:text-[#2d6a4f] transition-colors duration-200">
      <svg class="w-5 h-5 text-[#52b788] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/>
      </svg>
      Planes
    </a>
    <a href="#faq" class="mobile-link flex items-center gap-3 py-3 px-4 rounded-xl text-gray-700 font-medium hover:bg-[#f0fdf4] hover:text-[#2d6a4f] transition-colors duration-200">
      <svg class="w-5 h-5 text-[#52b788] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      Preguntas Frecuentes
    </a>
  </nav>

  <!-- CTA en drawer -->
  <div class="p-4 border-t border-gray-100">
    <a
      href="https://wa.me/573054188289"
      target="_blank"
      rel="noopener noreferrer"
      class="mobile-link flex items-center justify-center gap-2 w-full bg-[#2d6a4f] text-white py-3.5 px-6 rounded-xl font-semibold hover:bg-[#1b4332] transition-colors duration-300 shadow-md"
    >
      <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
      Contactar por WhatsApp
    </a>
  </div>
</aside>

<script>
  const mainNav = document.getElementById('main-nav');
  const menuToggle = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  const mobileOverlay = document.getElementById('mobile-overlay');
  const closeMenu = document.getElementById('close-menu');
  const hamburgerIcon = document.getElementById('hamburger-icon');
  const closeIcon = document.getElementById('close-icon');
  const mobileLinks = document.querySelectorAll('.mobile-link');

  window.addEventListener('scroll', () => {
    if (window.scrollY > 10) {
      mainNav?.classList.add('shadow-md');
    } else {
      mainNav?.classList.remove('shadow-md');
    }
  }, { passive: true });

  function openMenu() {
    mobileMenu?.classList.remove('translate-x-full');
    mobileMenu?.setAttribute('aria-hidden', 'false');
    mobileOverlay?.classList.remove('opacity-0', 'invisible');
    menuToggle?.setAttribute('aria-expanded', 'true');
    hamburgerIcon?.classList.add('hidden');
    closeIcon?.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }

  function closeMenuFn() {
    mobileMenu?.classList.add('translate-x-full');
    mobileMenu?.setAttribute('aria-hidden', 'true');
    mobileOverlay?.classList.add('opacity-0', 'invisible');
    menuToggle?.setAttribute('aria-expanded', 'false');
    hamburgerIcon?.classList.remove('hidden');
    closeIcon?.classList.add('hidden');
    document.body.style.overflow = '';
  }

  menuToggle?.addEventListener('click', openMenu);
  closeMenu?.addEventListener('click', closeMenuFn);
  mobileOverlay?.addEventListener('click', closeMenuFn);
  mobileLinks.forEach(link => link.addEventListener('click', closeMenuFn));
</script>
