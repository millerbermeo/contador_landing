---
const videos = [
  {
    id: "7402404368126987525",
    title: "Video de asesoría contable",
    cite: "https://www.tiktok.com/@bp.asesorias.contables/video/7402404368126987525",
  },
  {
    id: "7394242102835662086",
    title: "Declaración de Renta 2023 — Documentos requeridos",
    cite: "https://www.tiktok.com/@bp.asesorias.contables/video/7394242102835662086",
  },
  {
    id: "7391289223623494918",
    title: "Declaración de Renta — Sanciones",
    cite: "https://www.tiktok.com/@bp.asesorias.contables/video/7391289223623494918",
  },
];
---

<section class="py-24 bg-white">
  <div class="container mx-auto px-4 lg:px-8">

    <!-- Encabezado -->
    <div class="text-center mb-16" data-aos="fade-up">
      <span class="inline-block text-xs font-bold tracking-widest uppercase text-[#84b84b] bg-[#f3f3f3] border border-[#cbdbba] px-4 py-1.5 rounded-full mb-4">
        Redes Sociales
      </span>
      <h2 class="text-4xl lg:text-5xl font-extrabold text-[#2d4012] mb-4">
        Contenido en <span class="text-[#486d21]">TikTok</span>
      </h2>
      <p class="text-lg text-gray-500 max-w-2xl mx-auto">
        Síguenos para recibir consejos prácticos sobre contabilidad y finanzas.
      </p>
      <a
        href="https://www.tiktok.com/@bp.asesorias.contables"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 mt-6 bg-black text-white px-6 py-2.5 rounded-full text-sm font-semibold hover:bg-gray-800 transition-colors duration-300 shadow-md"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.18 8.18 0 004.78 1.52V6.74a4.84 4.84 0 01-1.01-.05z"/>
        </svg>
        @bp.asesorias.contables
      </a>
    </div>

    <!-- Embeds TikTok -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
      {videos.map((video, i) => (
        <div
          class="bg-[#f3f3f3] border border-gray-100 rounded-2xl overflow-hidden shadow-sm hover:shadow-lg transition-shadow duration-300"
          data-aos="fade-up"
          data-aos-delay={i * 120}
        >
          <div class="p-4 border-b border-gray-100">
            <div class="flex items-center gap-2">
              <div class="w-8 h-8 rounded-full bg-black flex items-center justify-center">
                <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.18 8.18 0 004.78 1.52V6.74a4.84 4.84 0 01-1.01-.05z"/>
                </svg>
              </div>
              <span class="text-sm font-semibold text-gray-700">@bp.asesorias.contables</span>
            </div>
            <p class="mt-2 text-xs text-gray-500 leading-snug">{video.title}</p>
          </div>

          <blockquote
            class="tiktok-embed"
            cite={video.cite}
            data-video-id={video.id}
            style="max-width:100%;min-width:280px;"
          >
            <section>
              <a
                target="_blank"
                title="@bp.asesorias.contables"
                href="https://www.tiktok.com/@bp.asesorias.contables?refer=embed"
              >@bp.asesorias.contables</a>
            </section>
          </blockquote>
        </div>
      ))}
    </div>
  </div>
</section>

<script is:inline async src="https://www.tiktok.com/embed.js"></script>
