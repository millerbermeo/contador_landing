---
export interface ServiceProps {
  icon: string;
  title: string;
  items: string[];
  whatsappMessage: string;
  delay?: number;
}

const { icon, title, items, whatsappMessage, delay = 0 } = Astro.props;
---

<article
  class="group bg-white rounded-2xl shadow-sm border border-gray-100 hover:shadow-xl hover:-translate-y-2 transition-all duration-300 flex flex-col overflow-hidden"
  data-aos="fade-up"
  data-aos-delay={delay}
>
  <!-- Cabecera verde -->
  <div class="bg-gradient-to-br from-[#2d6a4f] to-[#1b4332] p-6 flex items-center gap-4">
    <div class="w-14 h-14 rounded-xl bg-white/10 border border-white/20 flex items-center justify-center shrink-0 overflow-hidden">
      <img
        src={`/${icon}`}
        alt={`Ícono de ${title}`}
        class="w-10 h-10 object-contain"
        loading="lazy"
      />
    </div>
    <h3 class="text-lg font-bold text-white leading-tight">{title}</h3>
  </div>

  <!-- Contenido -->
  <div class="p-6 flex flex-col flex-1">
    <ul class="space-y-3 flex-1 mb-6" role="list">
      {items.map((item: string) => (
        <li class="flex items-start gap-3 text-gray-600 text-sm leading-relaxed">
          <span class="mt-0.5 shrink-0 w-5 h-5 rounded-full bg-[#f0fdf4] border border-[#b7e4c7] flex items-center justify-center" aria-hidden="true">
            <svg class="w-3 h-3 text-[#2d6a4f]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
            </svg>
          </span>
          {item}
        </li>
      ))}
    </ul>

    <!-- CTA WhatsApp -->
    <a
      href={`https://api.whatsapp.com/send?phone=573054188289&text=${encodeURIComponent(whatsappMessage)}`}
      target="_blank"
      rel="noopener noreferrer"
      aria-label={`Contactar sobre ${title}`}
      class="flex items-center justify-center gap-2 w-full bg-[#f0fdf4] text-[#2d6a4f] border border-[#b7e4c7] py-3 px-5 rounded-xl font-semibold text-sm hover:bg-[#2d6a4f] hover:text-white hover:border-[#2d6a4f] transition-all duration-300 group/btn"
    >
      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
      Solicitar por WhatsApp
    </a>
  </div>
</article>
