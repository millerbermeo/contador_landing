---
const articles = [
  {
    title: "Suscripción Gratuita a Actualícese",
    link: "https://actualicese.com/suscripcion-gratuita/",
    description: "Obtén acceso a información contable y fiscal actualizada de Colombia.",
    image: "contaduria-1.jpg",
    category: "Recursos",
  },
  {
    title: "Leyes con Contenido Tributario y Contable",
    link: "https://www.ambitojuridico.com/noticias/blog-contable-yo-tributario/tributario-y-contable/leyes-con-contenido-tributario-y",
    description: "Descubra las leyes recientes que impactan el ámbito tributario.",
    image: "contaduria-2.jpg",
    category: "Legislación",
  },
  {
    title: "Guía Tributaria 2024 para Fiscales y Contables en Colombia",
    link: "https://jlcauditors.com/guia-tributaria-2024-fiscales-contables-colombia/",
    description: "Una guía completa sobre obligaciones fiscales para el año 2024.",
    image: "contaduria-3.jpg",
    category: "Guía",
  },
  {
    title: "Comunidad Contable",
    link: "https://www.comunidadcontable.com/home.asp",
    description: "Recursos y herramientas para contadores en Colombia.",
    image: "contaduria-4.jpg",
    category: "Comunidad",
  },
];
---

<section class="py-24 bg-[#f3f3f3]">
  <div class="container mx-auto px-4 lg:px-8">

    <!-- Encabezado -->
    <div class="text-center mb-16" data-aos="fade-up">
      <span class="inline-block text-xs font-bold tracking-widest uppercase text-[#84b84b] bg-[#f3f3f3] border border-[#cbdbba] px-4 py-1.5 rounded-full mb-4">
        Recursos
      </span>
      <h2 class="text-4xl lg:text-5xl font-extrabold text-[#2d4012] mb-4">
        Artículos de Interés
      </h2>
      <p class="text-lg text-gray-500 max-w-2xl mx-auto">
        Información actualizada sobre contabilidad, fiscalidad y normativas en Colombia.
      </p>
    </div>

    <!-- Grid de artículos -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {articles.map((article, i) => (
        <a
          href={article.link}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`Leer artículo: ${article.title}`}
          class="group bg-white rounded-2xl overflow-hidden shadow-sm border border-gray-100 hover:shadow-xl hover:-translate-y-1.5 transition-all duration-300 flex flex-col"
          data-aos="fade-up"
          data-aos-delay={i * 100}
        >
          <!-- Imagen -->
          <div class="relative h-48 overflow-hidden">
            <img
              src={`/${article.image}`}
              alt={article.title}
              class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
            <!-- Badge de categoría -->
            <span class="absolute top-3 left-3 bg-[#486d21]/90 text-white text-xs font-semibold px-3 py-1 rounded-full backdrop-blur-sm">
              {article.category}
            </span>
          </div>

          <!-- Contenido -->
          <div class="p-5 flex flex-col flex-1">
            <h3 class="font-bold text-[#2d4012] text-base leading-snug mb-2 group-hover:text-[#486d21] transition-colors line-clamp-2">
              {article.title}
            </h3>
            <p class="text-gray-500 text-sm leading-relaxed flex-1">
              {article.description}
            </p>
            <div class="flex items-center gap-1.5 mt-4 text-[#84b84b] text-sm font-semibold">
              Leer más
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
